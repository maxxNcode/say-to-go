{
  "name": "say-to-go",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Experience different places virtually by just saying the place using voice recognition",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,js,css}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "serve": "^14.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["voice-recognition","teleportation","mapillary","openstreetmap","360-view","virtual-travel"],
  "author": "Mark Froilan Lendio (maxxNcode)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxxNcode/say-to-go.git"
  },
  "bugs": {
    "url": "https://github.com/maxxNcode/say-to-go/issues"
  },
  "homepage": "https://github.com/maxxNcode/say-to-go#readme"
}
